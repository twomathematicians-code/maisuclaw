# ── MaisuClaw Environment Variables ─────────────
# Copy this file to .env and fill in your keys

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434

# Groq Cloud (Free tier — get key at https://console.groq.com/keys)
GROQ_API_KEY=

# OpenRouter Cloud (Free models — get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# GitHub Backup (optional)
GITHUB_TOKEN=
GITHUB_REPO=

# Server
MAISUCLAW_HOST=0.0.0.0
MAISUCLAW_PORT=8000
